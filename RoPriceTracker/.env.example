# 這個檔案是「選填設定」。一般情況你不用改，直接用預設值即可。
# 登入 gnjoy 是在 App 網頁上點「登入 gnjoy」手動登入，不需要在這裡填帳密。

# 物價查詢頁（通常不用改）
RO_SEARCH_URL=https://event.gnjoy.com.tw/Ro/RoShopSearch

# 本機網頁介面的埠號
PORT=5178

# 「登入」一律用你電腦真正的 Edge/Chrome（才能通過 gnjoy 的驗證）。
# 下面這個只影響「背景查價」用哪個瀏覽器：chromium（預設）/ firefox / chrome
RO_BROWSER=chromium

# 選填：登入時若找不到 Edge/Chrome，可指定瀏覽器執行檔完整路徑
# RO_REAL_BROWSER_PATH=C:\Program Files (x86)\Microsoft Edge\Application\msedge.exe

# 選填：登入用的除錯連接埠（預設 9222，通常不用改）
# RO_CDP_PORT=9222

# 自動更新時是否用「無頭」瀏覽器（true=背景執行看不到視窗）。
# 手動登入的視窗一定看得到，這個設定不影響登入。
HEADLESS=true

# 選填：萬一 Playwright 找不到瀏覽器，可指定 chrome 執行檔完整路徑
# PW_EXECUTABLE_PATH=
