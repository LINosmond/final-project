# ===== 複製這個檔案成 .env，再把下面填成你自己的 =====
# （.env 已經被 .gitignore 擋掉，不會上傳到 git）

# 你的 gnjoy 帳號與密碼
RO_ACCOUNT=你的帳號
RO_PASSWORD=你的密碼

# 物價查詢頁（通常不用改）
RO_SEARCH_URL=https://event.gnjoy.com.tw/Ro/RoShopSearch

# 登入頁網址。若留空，程式會嘗試在查詢頁上直接找登入欄位。
# 之後我們對過實際頁面後，可能會把這裡改成真正的登入網址。
RO_LOGIN_URL=

# 本機網頁介面的埠號
PORT=5178

# 是否用「無頭」瀏覽器（true=背景執行看不到視窗；除錯時可設 false 看畫面）
HEADLESS=true
